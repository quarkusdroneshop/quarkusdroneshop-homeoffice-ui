{
  "name": "quarkusdroneshop-homeoffice-ui",
  "version": "0.1.5",
  "description": "UI for Quarkus Droneshop Homeoffice",
  "main": "server.js",
  "repository": "https://github.com/quarkusdroneshop/quarkusdroneshop-homeoffice-ui.git",
  "homepage": "https://github.com/quarkusdroneshop/quarkusdroneshop-homeoffice-ui",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prebuild": "npm run clean",
    "dr:surge": "node dr-surge.js",
    "build": "webpack --config webpack.prod.js && npm run dr:surge",
    "start": "node server.js",
    "start:dev": "webpack serve --hot --color --progress --config webpack.dev.js",
    "test": "jest",
    "test:json": "jest --json --outputFile=test-results/jest-results.json",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report playwright-report",
    "eslint": "eslint --ext .tsx,.ts,.js ./src/",
    "lint": "npm run eslint",
    "format": "prettier --check --write ./src/**/*.{tsx,ts}",
    "type-check": "tsc --noEmit",
    "ci-checks": "npm run type-check && npm run lint && npm run test",
    "build:bundle-profile": "webpack --config webpack.prod.js --profile --json > stats.json",
    "bundle-profile:analyze": "npm run build:bundle-profile && webpack-bundle-analyzer ./stats.json",
    "clean": "rimraf dist",
    "storybook": "start-storybook -p 6006",
    "build:storybook": "build-storybook",
    "scan:semgrep": "semgrep --config=auto --error src/",
    "scan:secrets": "gitleaks detect --source . --verbose",
    "scan:trivy": "trivy fs --exit-code 1 --severity HIGH,CRITICAL .",
    "scan:dast:wapiti": "docker run --rm -t cyberaz0r/wapiti wapiti -u http://host.docker.internal:8080 --scope page -f json -o /tmp/wapiti-report.json --flush-session --max-links-per-page 50 --max-scan-time 300",
    "scan:all": "npm run scan:semgrep && npm run scan:secrets && npm run scan:trivy",
    "lint:json": "eslint --ext .tsx,.ts,.js ./src/ --format json --output-file test-results/eslint-report.json || true",
    "report:collect": "npm run test:json && npm run lint:json",
    "report:generate": "python3 src/test/scripts/generate-report.py test-results quarkusdroneshop-homeoffice-ui",
    "report": "npm run report:collect && npm run report:generate"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/react-router-dom": "^5.3.3",
    "@types/victory": "^33.1.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.2",
    "prettier": "^3.5.3",
    "raw-loader": "^4.0.2",
    "react-docgen-typescript-loader": "^3.7.2",
    "react-router-dom": "^5.3.4",
    "regenerator-runtime": "^0.14.1",
    "rimraf": "^6.0.1",
    "style-loader": "^4.0.0",
    "svg-url-loader": "^8.0.0",
    "terser-webpack-plugin": "^5.3.11",
    "ts-jest": "^29.3.4",
    "ts-loader": "^9.5.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "url-loader": "^4.1.1",
    "webpack": "^5.99.9",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^5.10.0"
  },
  "dependencies": {
    "@axe-core/react": "^4.10.1",
    "@apollo/react-hooks": "^4.0.0",
    "@patternfly/react-charts": "^7.2.0",
    "@patternfly/react-core": "^4.278.1",
    "@patternfly/react-icons": "^4.9.2",
    "@patternfly/react-styles": "^4.8.2",
    "apollo-cache-inmemory": "^1.6.6",
    "apollo-client": "^2.6.10",
    "apollo-link-http": "^1.5.17",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "express": "^4.21.2",
    "graphql": "^15.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-last-location": "^2.0.1",
    "react-use": "^17.6.0",
    "recharts": "^2.15.3",
    "victory-core": "^36.9.2"
  }
}
